{
  "manifest_version": 3,
  "name": "Eyebrak",
  "version": "1.1",
  "description": "Smart breaks, Pomodoro cycles, eye care tips, and streak tracking for digital wellness.",
  "permissions": ["storage", "notifications", "alarms", "idle", "activeTab", "scripting"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": { "default_popup": "popup.html", "default_icon": { "16": "icons/icon16.png","48": "icons/icon48.png","128": "icons/icon128.png" } },
  "options_page": "options.html",
  "icons": { "16": "icons/icon16.png","48": "icons/icon48.png","128": "icons/icon128.png" }
}
